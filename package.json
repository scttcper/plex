{
  "name": "@ctrl/plex",
  "version": "0.0.0-placeholder",
  "description": "Plex api client in typescript using ofetch",
  "keywords": [
    "plex",
    "typescript"
  ],
  "license": "MIT",
  "author": "Scott Cooper <scttcper@gmail.com>",
  "repository": "scttcper/plex",
  "files": [
    "dist/src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "typings": "./dist/src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint . && oxfmt --check",
    "lint:fix": "oxlint . --fix && oxfmt",
    "prepare": "pnpm run build",
    "build": "tsc",
    "build:docs": "typedoc",
    "test": "vitest run",
    "bootstraptest": "tsx scripts/bootstraptest.ts --create-photos",
    "teardowntest": "tsx scripts/teardowntest.ts",
    "add-media": "tsx scripts/add-media.ts",
    "test-cleanup": "tsx scripts/test-cleanup.ts"
  },
  "dependencies": {
    "@ctrl/mac-address": "^3.1.0",
    "ofetch": "^1.5.1",
    "type-fest": "^5.6.0",
    "ws": "^8.20.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@ctrl/oxlint-config": "1.5.0",
    "@ctrl/video-filename-parser": "5.4.1",
    "@sindresorhus/tsconfig": "8.1.0",
    "@types/node": "25.8.0",
    "@types/ws": "8.18.1",
    "@types/xml2js": "0.4.14",
    "execa": "9.6.1",
    "globby": "16.2.0",
    "make-dir": "5.1.0",
    "ora": "9.4.0",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "p-retry": "8.0.0",
    "prettier": "3.8.3",
    "tsx": "4.22.1",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "release": {
    "branches": [
      "master"
    ]
  },
  "engines": {
    "node": ">20"
  },
  "packageManager": "pnpm@11.1.2"
}
